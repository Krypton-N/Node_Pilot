# Puerto del backend Express (el devServer del frontend usa el 3000)
PORT=8080

# Conexión MySQL (Sequelize)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nodepilot
DB_USER=root
DB_PASSWORD=

# LLM — Asistente de IA (SDK de OpenAI apuntando a OpenRouter, modelos free).
# Las variables mantienen el prefijo DEEPSEEK_ por compatibilidad con el código.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL_PRO=qwen/qwen-2.5-coder-32b-instruct:free
DEEPSEEK_MODEL_FLASH=qwen/qwen-2.5-coder-32b-instruct:free
